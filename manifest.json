{
  "name": "Gig Timer",
  "description": "Gig Timer tracks how long each contract takes.",
  "version": "1.0",
  "manifest_version": 3,
  "options_page": "html/options.html",
  "action": {
    "default_popup": "html/popup.html",
    "default_title": "Gig Timer"
  },
  "host_permissions": ["*://*/*"],
  "permissions": ["storage", "tabs", "activeTab", "webNavigation"],
  "background": {
    "service_worker": "./service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": [
        "bridge/inject-bridge.js",
        "js/stopwatch.js",
        "js/assignments.js",
        "js/workplace.js",
        "js/idle-overlay.js",
        "js/popup.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "matches": ["*://*/*"],
      "resources": ["js/bridge.js"]
    }
  ]
}
